<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> — Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #13141a; color: #fff; font-family: 'Segoe UI', sans-serif; display: flex; min-height: 100vh; }

    /* Sidebar */
    .sidebar { width: 240px; background: #1e1f28; border-right: 1px solid #2e2f3e; display: flex; flex-direction: column; position: fixed; height: 100vh; overflow-y: auto; }
    .sidebar-header { padding: 20px 16px; border-bottom: 1px solid #2e2f3e; display: flex; align-items: center; gap: 12px; }
    .sidebar-header img { width: 40px; height: 40px; border-radius: 50%; }
    .sidebar-header .icon-placeholder { width: 40px; height: 40px; border-radius: 50%; background: #7c6dff; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
    .sidebar-header h2 { font-size: 0.9rem; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sidebar nav { padding: 12px 8px; flex: 1; }
    .nav-label { font-size: 0.7rem; color: #72748a; text-transform: uppercase; letter-spacing: 0.08em; padding: 8px 8px 4px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; text-decoration: none; color: #9a9ab0; font-size: 0.9rem; transition: all 0.15s; margin-bottom: 2px; cursor: pointer; }
    .nav-item:hover, .nav-item.active { background: #2e2f3e; color: #fff; }
    .nav-item.active { color: #7c6dff; }
    .nav-icon { font-size: 1.1rem; width: 20px; text-align: center; }
    .sidebar-footer { padding: 16px; border-top: 1px solid #2e2f3e; }
    .sidebar-footer a { color: #72748a; text-decoration: none; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; }
    .sidebar-footer a:hover { color: #fff; }

    /* Main content */
    .main { margin-left: 240px; flex: 1; padding: 32px; max-width: calc(100% - 240px); }
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 4px; }
    .page-header p { color: #72748a; font-size: 0.9rem; }

    /* Cards */
    .card { background: #1e1f28; border: 1px solid #2e2f3e; border-radius: 12px; padding: 24px; margin-bottom: 16px; }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .card-title { font-size: 1rem; font-weight: 600; display: flex; align-items: center; gap: 8px; }
    .card-title .icon { font-size: 1.2rem; }

    /* Toggle */
    .toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #2e2f3e; }
    .toggle-row:last-child { border-bottom: none; }
    .toggle-info h4 { font-size: 0.9rem; font-weight: 600; margin-bottom: 2px; }
    .toggle-info p { font-size: 0.8rem; color: #72748a; }
    .toggle { position: relative; width: 44px; height: 24px; }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle-slider { position: absolute; inset: 0; background: #2e2f3e; border-radius: 24px; cursor: pointer; transition: 0.2s; }
    .toggle-slider:before { content: ""; position: absolute; width: 18px; height: 18px; left: 3px; top: 3px; background: #fff; border-radius: 50%; transition: 0.2s; }
    input:checked + .toggle-slider { background: #7c6dff; }
    input:checked + .toggle-slider:before { transform: translateX(20px); }

    /* Form */
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 0.85rem; color: #9a9ab0; margin-bottom: 6px; }
    .form-group input, .form-group select, .form-group textarea { width: 100%; background: #13141a; border: 1px solid #2e2f3e; border-radius: 8px; padding: 10px 14px; color: #fff; font-size: 0.9rem; outline: none; transition: border 0.15s; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: #7c6dff; }
    .form-group select option { background: #1e1f28; }

    /* Buttons */
    .btn { padding: 10px 20px; border-radius: 8px; border: none; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.15s; }
    .btn-primary { background: #7c6dff; color: #fff; }
    .btn-primary:hover { background: #6a5ce8; }
    .btn-danger { background: #ed4245; color: #fff; }
    .btn-danger:hover { background: #c03537; }
    .btn-secondary { background: #2e2f3e; color: #fff; }
    .btn-secondary:hover { background: #3a3b4e; }

    /* Section pages */
    .section { display: none; }
    .section.active { display: block; }

    /* Stats row */
    .stats-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; margin-bottom: 24px; }
    .stat-card { background: #1e1f28; border: 1px solid #2e2f3e; border-radius: 10px; padding: 16px; }
    .stat-card .stat-value { font-size: 1.6rem; font-weight: 700; color: #7c6dff; }
    .stat-card .stat-label { font-size: 0.8rem; color: #72748a; margin-top: 4px; }

    /* Mobile */
    .mobile-menu-btn { display: none; position: fixed; bottom: 20px; right: 20px; background: #7c6dff; border: none; color: #fff; width: 48px; height: 48px; border-radius: 50%; font-size: 1.4rem; cursor: pointer; z-index: 100; }
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); transition: 0.25s; z-index: 50; }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; max-width: 100%; padding: 20px 16px; }
      .mobile-menu-btn { display: flex; align-items: center; justify-content: center; }
    }

    .toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: #57f287; color: #13141a; padding: 12px 24px; border-radius: 8px; font-weight: 600; font-size: 0.9rem; opacity: 0; transition: opacity 0.3s; z-index: 200; }
    .toast.show { opacity: 1; }
  </style>
</head>
<body>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <% if (guild.icon) { %>
        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="icon">
      <% } else { %>
        <div class="icon-placeholder"><%= guild.name.charAt(0) %></div>
      <% } %>
      <h2><%= guild.name %></h2>
    </div>

    <nav>
      <div class="nav-label">Overview</div>
      <a class="nav-item active" onclick="showSection('overview')">
        <span class="nav-icon">📊</span> Overview
      </a>

      <div class="nav-label">Features</div>
      <a class="nav-item" onclick="showSection('welcome')">
        <span class="nav-icon">👋</span> Welcome
      </a>
      <a class="nav-item" onclick="showSection('verification')">
        <span class="nav-icon">🛡️</span> Verification
      </a>
      <a class="nav-item" onclick="showSection('autoreaction')">
        <span class="nav-icon">⚡</span> Auto Reaction
      </a>
      <a class="nav-item" onclick="showSection('sticky')">
        <span class="nav-icon">📌</span> Sticky
      </a>
      <a class="nav-item" onclick="showSection('invites')">
        <span class="nav-icon">📨</span> Invites
      </a>
    </nav>

    <div class="sidebar-footer">
      <a href="/dashboard">← Back to Servers</a>
    </div>
  </aside>

  <main class="main">

    <!-- Overview -->
    <div class="section active" id="section-overview">
      <div class="page-header">
        <h1>Overview</h1>
        <p>Welcome to your server dashboard.</p>
      </div>
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-value"><%= guild.approximate_member_count || '—' %></div>
          <div class="stat-label">Members</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#57f287"><%= settings.modules_enabled || 0 %></div>
          <div class="stat-label">Modules Active</div>
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="card-title"><span class="icon">⚙️</span> Quick Settings</div>
        </div>
        <div class="toggle-row">
          <div class="toggle-info"><h4>Welcome Messages</h4><p>Send a card when a member joins</p></div>
          <label class="toggle"><input type="checkbox" <%= settings.welcome_enabled ? 'checked' : '' %> onchange="saveSetting('welcome_enabled', this.checked)"><span class="toggle-slider"></span></label>
        </div>
        <div class="toggle-row">
          <div class="toggle-info"><h4>Verification</h4><p>Require members to verify on join</p></div>
          <label class="toggle"><input type="checkbox" <%= settings.verification_enabled ? 'checked' : '' %> onchange="saveSetting('verification_enabled', this.checked)"><span class="toggle-slider"></span></label>
        </div>
        <div class="toggle-row">
          <div class="toggle-info"><h4>Invite Tracking</h4><p>Track who invited each member</p></div>
          <label class="toggle"><input type="checkbox" <%= settings.invites_enabled ? 'checked' : '' %> onchange="saveSetting('invites_enabled', this.checked)"><span class="toggle-slider"></span></label>
        </div>
      </div>
    </div>

    <!-- Welcome -->
    <div class="section" id="section-welcome">
      <div class="page-header">
        <h1>👋 Welcome</h1>
        <p>Configure welcome messages for new members.</p>
      </div>
      <div class="card">
        <div class="form-group">
          <label>Welcome Channel</label>
          <select onchange="saveSetting('welcome_channel', this.value)">
            <option value="">— Select a channel —</option>
            <% channels.filter(c => c.type === 0).forEach(c => { %>
              <option value="<%= c.id %>" <%= settings.welcome_channel === c.id ? 'selected' : '' %>>#<%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Welcome Message</label>
          <input type="text" placeholder="Welcome {user} to {server}!" value="<%= settings.welcome_message || '' %>" onchange="saveSetting('welcome_message', this.value)">
        </div>
        <button class="btn btn-primary" onclick="saveAll()">Save Changes</button>
      </div>
    </div>

    <!-- Verification -->
    <div class="section" id="section-verification">
      <div class="page-header">
        <h1>🛡️ Verification</h1>
        <p>Set up word-based member verification.</p>
      </div>
      <div class="card">
        <div class="form-group">
          <label>Verification Channel</label>
          <select onchange="saveSetting('verify_channel', this.value)">
            <option value="">— Select a channel —</option>
            <% channels.filter(c => c.type === 0).forEach(c => { %>
              <option value="<%= c.id %>" <%= settings.verify_channel === c.id ? 'selected' : '' %>>#<%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Verified Role</label>
          <select onchange="saveSetting('verify_role', this.value)">
            <option value="">— Select a role —</option>
            <% roles.forEach(r => { %>
              <option value="<%= r.id %>" <%= settings.verify_role === r.id ? 'selected' : '' %>><%= r.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Verification Word</label>
          <input type="text" placeholder="verify" value="<%= settings.verify_word || 'verify' %>" onchange="saveSetting('verify_word', this.value)">
        </div>
        <div class="form-group">
          <label>Card Description</label>
          <textarea rows="3" placeholder="Type the word below to gain access..." onchange="saveSetting('verify_desc', this.value)"><%= settings.verify_desc || '' %></textarea>
        </div>
        <button class="btn btn-primary" onclick="saveAll()">Save Changes</button>
      </div>
    </div>

    <!-- Auto Reaction -->
    <div class="section" id="section-autoreaction">
      <div class="page-header">
        <h1>⚡ Auto Reaction</h1>
        <p>Auto-react to messages in specific channels.</p>
      </div>
      <div class="card">
        <div class="form-group">
          <label>Channel</label>
          <select id="react-channel">
            <option value="">— Select a channel —</option>
            <% channels.filter(c => c.type === 0).forEach(c => { %>
              <option value="<%= c.id %>">#<%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Emojis (space separated)</label>
          <input type="text" id="react-emojis" placeholder="👍 🔥 ❤️">
        </div>
        <button class="btn btn-primary" onclick="saveAll()">Add Reaction</button>
      </div>
    </div>

    <!-- Sticky -->
    <div class="section" id="section-sticky">
      <div class="page-header">
        <h1>📌 Sticky</h1>
        <p>Pin messages to the bottom of channels.</p>
      </div>
      <div class="card">
        <div class="form-group">
          <label>Channel</label>
          <select onchange="saveSetting('sticky_channel', this.value)">
            <option value="">— Select a channel —</option>
            <% channels.filter(c => c.type === 0).forEach(c => { %>
              <option value="<%= c.id %>" <%= settings.sticky_channel === c.id ? 'selected' : '' %>>#<%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Sticky Message</label>
          <textarea rows="3" placeholder="This message will stay at the bottom..." onchange="saveSetting('sticky_message', this.value)"><%= settings.sticky_message || '' %></textarea>
        </div>
        <button class="btn btn-primary" onclick="saveAll()">Save Changes</button>
      </div>
    </div>

    <!-- Invites -->
    <div class="section" id="section-invites">
      <div class="page-header">
        <h1>📨 Invites</h1>
        <p>Configure invite tracking settings.</p>
      </div>
      <div class="card">
        <div class="form-group">
          <label>Log Channel</label>
          <select onchange="saveSetting('invite_log_channel', this.value)">
            <option value="">— Select a channel —</option>
            <% channels.filter(c => c.type === 0).forEach(c => { %>
              <option value="<%= c.id %>" <%= settings.invite_log_channel === c.id ? 'selected' : '' %>>#<%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Fake Account Threshold (days)</label>
          <input type="number" min="1" max="30" value="<%= settings.fake_threshold || 7 %>" onchange="saveSetting('fake_threshold', this.value)">
        </div>
        <div class="toggle-row">
          <div class="toggle-info"><h4>Count Rejoins</h4><p>Count rejoining members as invites</p></div>
          <label class="toggle"><input type="checkbox" <%= settings.count_rejoins ? 'checked' : '' %> onchange="saveSetting('count_rejoins', this.checked)"><span class="toggle-slider"></span></label>
        </div>
        <div class="toggle-row" style="margin-top:12px">
          <div class="toggle-info"><h4>Count Fakes</h4><p>Count fake accounts in invite total</p></div>
          <label class="toggle"><input type="checkbox" <%= settings.count_fakes ? 'checked' : '' %> onchange="saveSetting('count_fakes', this.checked)"><span class="toggle-slider"></span></label>
        </div>
        <br>
        <button class="btn btn-primary" onclick="saveAll()">Save Changes</button>
      </div>
    </div>

  </main>

  <button class="mobile-menu-btn" onclick="toggleSidebar()">☰</button>
  <div class="toast" id="toast">Saved!</div>

  <script>
    const guildId = '<%= guild.id %>';
    let pendingSettings = {};

    function showSection(name) {
      document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
      document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
      document.getElementById('section-' + name).classList.add('active');
      event.currentTarget.classList.add('active');
      if (window.innerWidth <= 768) document.getElementById('sidebar').classList.remove('open');
    }

    function saveSetting(key, value) {
      pendingSettings[key] = value;
    }

    async function saveAll() {
      try {
        await fetch(`/api/guild/${guildId}/settings`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(pendingSettings)
        });
        pendingSettings = {};
        showToast('Saved!');
      } catch (e) {
        showToast('Error saving!');
      }
    }

    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
    }
  </script>

</body>
</html>
