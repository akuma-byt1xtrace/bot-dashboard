<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Error</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #13141a; color: #fff; font-family: 'Segoe UI', sans-serif;
           display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    h1 { font-size: 5rem; color: #7c6dff; }
    p { color: #72748a; margin: 12px 0 32px; }
    a { color: #7c6dff; }
  </style>
</head>
<body>
  <div style="text-align:center">
    <h1><%= code %></h1>
    <p><%= message %></p>
    <a href="/">Go home</a>
  </div>
</body>
</html>
