<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bot Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #13141a; color: #fff; font-family: 'Segoe UI', sans-serif;
           display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .card { text-align: center; padding: 48px; }
    h1 { font-size: 2.5rem; margin-bottom: 12px; }
    p { color: #72748a; margin-bottom: 32px; }
    a.btn { background: #7c6dff; color: #fff; padding: 14px 32px; border-radius: 8px;
            text-decoration: none; font-weight: 600; }
    a.btn:hover { background: #6a5ce8; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Bot Dashboard</h1>
    <p>Manage your Discord server settings in one place.</p>
    <% if (user) { %>
      <a class="btn" href="/dashboard">Go to Dashboard</a>
    <% } else { %>
      <a class="btn" href="/auth/login">Login with Discord</a>
    <% } %>
  </div>
</body>
</html>
